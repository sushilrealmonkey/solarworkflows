VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_QA_TEST_PASSWORD=
VITE_QA_TEST_ACCOUNTS=

# Server-only setup values. Never prefix private keys with VITE_.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=
APP_BASE_URL=
# Comma-separated extra app origins allowed to set invite/reset email links via the
# request Origin header (e.g. https://app.getbizlee.com,https://solarcrm.realmonkey.ai).
# Any Origin not listed here (and not equal to APP_BASE_URL) falls back to APP_BASE_URL.
APP_ALLOWED_ORIGINS=
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_FULL_NAME=

# Supabase Auth Send SMS Hook. Generate a unique Standard Webhooks secret in
# the form v1,whsec_<base64> and use the same value in the hook and function.
SEND_SMS_HOOK_URI=
SEND_SMS_HOOK_SECRET=

# Required Black SMS server-only credentials.
BLACKSMS_API_KEY=
BLACKSMS_SENDER_ID=
